# Foundry build artifacts (regenerated by `forge build`)
out/
cache/

# Foundry deploy / broadcast logs (must NEVER be committed — may
# contain RPC URLs, signed tx, etc.)
broadcast/

# Local environment overrides
.env
.env.local

# IDE
.idea/
.vscode/

# Test dependencies (forge-std) are NOT committed to keep the repo lean.
# Install before running the suite (one command, see the EVM testnet guide):
#   forge install foundry-rs/forge-std --no-commit
# or a history-stripped clone into lib/forge-std. Tests are reproducible
# from that single step; the contract sources here are the committed artifact.
lib/
