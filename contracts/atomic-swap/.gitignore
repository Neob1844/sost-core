# Foundry build artifacts (regenerated by `forge build`)
out/
cache/

# Foundry deploy / broadcast logs (must NEVER be committed — may
# contain RPC URLs, signed tx, etc.)
broadcast/

# Local environment overrides
.env
.env.local

# IDE
.idea/
.vscode/

# Skip nested .git from forge-std clone (forge init doesn't create
# a submodule; we vendor the lib directly with its history stripped).
lib/forge-std/.git
