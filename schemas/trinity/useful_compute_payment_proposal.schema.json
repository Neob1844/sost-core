{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-payment-proposal/v0.1",
  "title": "Trinity Useful Compute Payment Proposal",
  "description": "Output of the Trinity payment proposal layer v0.1. Converts a reward budget plan plus a worker address map into a reviewable, signable-later proposal that lists payout_address, amount and reason per item. v0.1 is dry-run only: it NEVER signs, NEVER touches a wallet, NEVER broadcasts, NEVER calls an RPC. The proposal is the input to a future, governance-signed payment sprint.",
  "type": "object",
  "required": [
    "schema",
    "proposal_id",
    "mode",
    "pinned_time",
    "source_budget_id",
    "total_payable_stocks",
    "total_deferred_stocks",
    "total_unresolved_stocks",
    "payable_items",
    "unresolved_items",
    "deferred_items",
    "rejected_items",
    "capsule_summary",
    "safety_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-payment-proposal/v0.1"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^prop-[0-9a-f]{16}$"
    },
    "mode": {
      "type": "string",
      "enum": ["local-dry-run"]
    },
    "pinned_time": {
      "type": "string", "format": "date-time"
    },
    "source_budget_id": {
      "type": "string",
      "pattern": "^bud-[0-9a-f]{16}$"
    },
    "total_payable_stocks":   { "type": "integer", "minimum": 0 },
    "total_deferred_stocks":  { "type": "integer", "minimum": 0 },
    "total_unresolved_stocks":{ "type": "integer", "minimum": 0 },
    "payable_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id",
          "worker_result_ids",
          "payout_address",
          "allocated_stocks",
          "allocated_sost",
          "source_budget_id",
          "source_governance_batch_id",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "type": "string", "pattern": "^uc-[0-9a-f]{16,64}$"
          },
          "worker_result_ids": {
            "type": "array",
            "items": {
              "type": "string", "pattern": "^[0-9a-f]{16}$"
            }
          },
          "payout_address": {
            "type": "string", "pattern": "^sost1[0-9a-f]{40}$"
          },
          "allocated_stocks": { "type": "integer", "minimum": 0 },
          "allocated_sost":   { "type": "number",  "minimum": 0 },
          "source_budget_id": {
            "type": "string", "pattern": "^bud-[0-9a-f]{16}$"
          },
          "source_governance_batch_id": {
            "type": "string", "pattern": "^gov-[0-9a-f]{16}$"
          },
          "reason": {
            "type": "string", "minLength": 1, "maxLength": 256
          }
        }
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id",
          "worker_result_id",
          "allocated_stocks",
          "missing_lookup",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "type": "string", "pattern": "^uc-[0-9a-f]{16,64}$"
          },
          "worker_result_id": {
            "type": "string", "pattern": "^[0-9a-f]{16}$"
          },
          "allocated_stocks": { "type": "integer", "minimum": 0 },
          "missing_lookup": {
            "type": "string", "minLength": 1, "maxLength": 256
          },
          "reason": {
            "type": "string", "minLength": 1, "maxLength": 256
          }
        }
      }
    },
    "deferred_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id",
          "deferred_stocks",
          "source_budget_id",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "type": "string", "pattern": "^uc-[0-9a-f]{16,64}$"
          },
          "deferred_stocks": { "type": "integer", "minimum": 0 },
          "source_budget_id": {
            "type": "string", "pattern": "^bud-[0-9a-f]{16}$"
          },
          "reason": {
            "type": "string", "minLength": 1, "maxLength": 256
          }
        }
      }
    },
    "rejected_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id",
          "source_budget_id",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "type": "string", "minLength": 1, "maxLength": 128
          },
          "source_budget_id": {
            "type": "string", "minLength": 1, "maxLength": 64
          },
          "reason": {
            "type": "string", "minLength": 1, "maxLength": 256
          }
        }
      }
    },
    "capsule_summary": {
      "type": "object",
      "required": ["template", "text", "referenced_files"],
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "enum": ["useful_compute_reward_batch_v1"]
        },
        "text": {
          "type": "string", "minLength": 1, "maxLength": 512
        },
        "referenced_files": {
          "type": "object",
          "required": [
            "budget_id", "governance_batch_ids", "validation_ids"
          ],
          "additionalProperties": false,
          "properties": {
            "budget_id": {
              "type": "string",
              "pattern": "^bud-[0-9a-f]{16}$"
            },
            "governance_batch_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^gov-[0-9a-f]{16}$"
              }
            },
            "validation_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^val-[0-9a-f]{16}$"
              }
            }
          }
        }
      }
    },
    "safety_status": {
      "type": "object",
      "required": [
        "no_private_keys",
        "no_wallet_access",
        "no_signature",
        "no_broadcast",
        "proposal_only",
        "requires_manual_signing",
        "requires_separate_broadcast"
      ],
      "additionalProperties": false,
      "properties": {
        "no_private_keys":             { "type": "boolean", "const": true },
        "no_wallet_access":            { "type": "boolean", "const": true },
        "no_signature":                { "type": "boolean", "const": true },
        "no_broadcast":                { "type": "boolean", "const": true },
        "proposal_only":               { "type": "boolean", "const": true },
        "requires_manual_signing":     { "type": "boolean", "const": true },
        "requires_separate_broadcast": { "type": "boolean", "const": true }
      }
    }
  }
}
