{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-sprint-release-report/v0.1",
  "title": "Trinity Sprint Release Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_id",
    "pinned_time",
    "sprint_id",
    "branch",
    "current_branch",
    "branch_match",
    "base_ref",
    "head_commit",
    "head_commit_short",
    "base_commit",
    "base_commit_short",
    "repo_root_basename",
    "tree_status",
    "changed_files",
    "changed_files_count",
    "additions_total",
    "deletions_total",
    "commits_ahead",
    "commits_ahead_count",
    "pytest",
    "demo_artifacts",
    "demo_artifacts_count",
    "warnings",
    "ready_to_release",
    "require_clean_tracked_tree",
    "safety_status",
    "safety_flags"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-sprint-release-report/v0.1"
    },
    "report_id": {
      "type": "string",
      "pattern": "^tsr-[0-9a-f]{16}$"
    },
    "pinned_time": {
      "type": "string",
      "minLength": 10,
      "maxLength": 64
    },
    "sprint_id": {
      "type": "string",
      "pattern": "^sprint-[0-9A-Za-z.-]+$",
      "minLength": 8,
      "maxLength": 64
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "current_branch": {
      "type": "string",
      "maxLength": 200
    },
    "branch_match": {"type": "boolean"},
    "base_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "head_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "head_commit_short": {
      "type": "string",
      "maxLength": 16
    },
    "base_commit": {
      "type": "string",
      "pattern": "^([0-9a-f]{40})?$"
    },
    "base_commit_short": {
      "type": "string",
      "maxLength": 16
    },
    "repo_root_basename": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "tree_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tracked_dirty", "untracked_count", "untracked_allowed"],
      "properties": {
        "tracked_dirty":     {"type": "boolean"},
        "untracked_count":   {"type": "integer", "minimum": 0},
        "untracked_allowed": {"type": "boolean"}
      }
    },
    "changed_files": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "status", "additions", "deletions"],
        "properties": {
          "path":      {"type": "string", "minLength": 1, "maxLength": 400},
          "status":    {"type": "string", "minLength": 1, "maxLength": 32},
          "additions": {"type": "integer", "minimum": -1},
          "deletions": {"type": "integer", "minimum": -1}
        }
      }
    },
    "changed_files_count": {"type": "integer", "minimum": 0},
    "additions_total":     {"type": "integer", "minimum": 0},
    "deletions_total":     {"type": "integer", "minimum": 0},
    "commits_ahead": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sha_short", "subject"],
        "properties": {
          "sha_short": {
            "type": "string",
            "pattern": "^[0-9a-f]{7,16}$"
          },
          "subject":   {"type": "string", "minLength": 1, "maxLength": 200}
        }
      }
    },
    "commits_ahead_count": {"type": "integer", "minimum": 0},
    "pytest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ran", "target", "returncode",
        "passed", "failed", "skipped", "errors", "summary"
      ],
      "properties": {
        "ran":        {"type": "boolean"},
        "target":     {"type": "string", "maxLength": 200},
        "returncode": {"type": "integer", "minimum": -1, "maximum": 255},
        "passed":     {"type": "integer", "minimum": 0},
        "failed":     {"type": "integer", "minimum": 0},
        "skipped":    {"type": "integer", "minimum": 0},
        "errors":     {"type": "integer", "minimum": 0},
        "summary":    {"type": "string", "maxLength": 300}
      }
    },
    "demo_artifacts": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "path_basename", "schema", "summary"],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": [
              "autopilot_report",
              "dashboard",
              "daily_report",
              "trial_pack_manifest"
            ]
          },
          "path_basename": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "schema": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "summary": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "demo_artifacts_count": {"type": "integer", "minimum": 0},
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "ready_to_release": {"type": "boolean"},
    "require_clean_tracked_tree": {"type": "boolean"},
    "safety_status": {
      "type": "string",
      "enum": ["ok", "warning", "failed"]
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_git_push",
        "no_git_merge",
        "no_git_tag",
        "no_wallet_access",
        "no_signing",
        "no_broadcast",
        "no_network_required"
      ],
      "properties": {
        "no_git_push":         {"type": "boolean", "const": true},
        "no_git_merge":        {"type": "boolean", "const": true},
        "no_git_tag":          {"type": "boolean", "const": true},
        "no_wallet_access":    {"type": "boolean", "const": true},
        "no_signing":          {"type": "boolean", "const": true},
        "no_broadcast":        {"type": "boolean", "const": true},
        "no_network_required": {"type": "boolean", "const": true}
      }
    }
  }
}
