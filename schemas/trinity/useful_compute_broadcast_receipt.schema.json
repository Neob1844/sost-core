{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-broadcast-receipt/v0.2",
  "title": "Trinity Useful Compute Human Broadcast Receipt",
  "description": "Output of the Trinity Sprint 5.18 human broadcast guard. Records the result of validating a Sprint 5.17 real-signed payment draft and either dry-running or actually invoking sost-cli sendrawtransaction. NEVER auto-pays. NEVER signs. NEVER touches a wallet. v0.2 adds an audit trail for FAILED broadcast attempts: every invocation of --mode human-broadcast leaves a receipt on disk, including when the subprocess returns non-zero, when the stdout cannot be parsed, or when the node-returned txid does not match the draft's txid_if_signed. safety_status flags are const-locked so an offline reviewer can detect tampering trivially.",
  "type": "object",
  "required": [
    "schema",
    "receipt_id",
    "source_draft_id",
    "txid_if_signed",
    "txid_broadcast",
    "signed_tx_hex_sha256",
    "broadcast_attempted",
    "broadcast_performed",
    "broadcast_mode",
    "broadcast_result_status",
    "node_txid_observed",
    "node_stdout_sha256",
    "node_stderr_sha256",
    "confirmation_token_hash",
    "total_payment_stocks",
    "max_total_stocks",
    "pinned_time",
    "sost_cli_bin_hash",
    "safety_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-broadcast-receipt/v0.2"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^rcpt-[0-9a-f]{16}$"
    },
    "source_draft_id": {
      "type": "string",
      "pattern": "^draft-[0-9a-f]{16}$"
    },
    "txid_if_signed": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "txid_broadcast": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "signed_tx_hex_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "broadcast_attempted": { "type": "boolean" },
    "broadcast_performed": { "type": "boolean" },
    "broadcast_mode": {
      "type": "string",
      "enum": ["local-dry-run", "human-broadcast"]
    },
    "broadcast_result_status": {
      "type": "string",
      "enum": [
        "dry_run",
        "broadcasted",
        "node_rejected",
        "txid_mismatch",
        "parse_error"
      ]
    },
    "node_txid_observed": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "node_stdout_sha256": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "node_stderr_sha256": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "confirmation_token_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "total_payment_stocks": { "type": "integer", "minimum": 0 },
    "max_total_stocks":     { "type": "integer", "minimum": 0 },
    "pinned_time": { "type": "string", "minLength": 1, "maxLength": 64 },
    "sost_cli_bin_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "safety_status": {
      "type": "object",
      "required": [
        "human_broadcast_only",
        "requires_manual_confirmation",
        "no_private_keys",
        "no_wallet_access",
        "no_signing",
        "no_automatic_payout",
        "single_transaction_only"
      ],
      "additionalProperties": false,
      "properties": {
        "human_broadcast_only":         { "type": "boolean", "const": true },
        "requires_manual_confirmation": { "type": "boolean", "const": true },
        "no_private_keys":              { "type": "boolean", "const": true },
        "no_wallet_access":             { "type": "boolean", "const": true },
        "no_signing":                   { "type": "boolean", "const": true },
        "no_automatic_payout":          { "type": "boolean", "const": true },
        "single_transaction_only":      { "type": "boolean", "const": true }
      }
    }
  }
}
