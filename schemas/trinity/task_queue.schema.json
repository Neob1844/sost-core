{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-task-queue/v0.1",
  "title": "Trinity Task Queue",
  "description": "Top-level state file of the Trinity Useful Compute task queue. Produced and maintained by scripts/trinity/task_queue.py. The queue is a directory of JSON files: queue.json (this schema) plus subdirs pending/, running/, completed/, failed/ that each contain individual queue-item JSON files (see $defs/queue_item). v0.1 is local-dry-run only: the queue runner invokes useful_compute_operator_loop.py with --mode local-dry-run and the explicit confirmation token, then invokes governor_watchdog.py over the resulting decisions. It never opens a wallet, never signs, never broadcasts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "queue_id",
    "queue_dir_basename",
    "created_at",
    "updated_at",
    "items"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-task-queue/v0.1"
    },
    "queue_id": {
      "type": "string",
      "pattern": "^tq-[0-9a-f]{16}$"
    },
    "queue_dir_basename": {
      "type": "string", "minLength": 1, "maxLength": 256
    },
    "created_at": { "type": "string", "minLength": 1, "maxLength": 64 },
    "updated_at": { "type": "string", "minLength": 1, "maxLength": 64 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "queue_item_id", "status", "created_at", "updated_at"
        ],
        "properties": {
          "queue_item_id": {
            "type": "string",
            "pattern": "^qit-[0-9a-f]{16}$"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "created_at": { "type": "string", "minLength": 1, "maxLength": 64 },
          "updated_at": { "type": "string", "minLength": 1, "maxLength": 64 }
        }
      }
    }
  },
  "$defs": {
    "queue_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "queue_item_id",
        "request_json_path",
        "worker_address_map_path",
        "governor_policy_path",
        "request_json_path_basename",
        "worker_address_map_path_basename",
        "governor_policy_path_basename",
        "status",
        "created_at",
        "updated_at",
        "pinned_time",
        "attempt_count",
        "max_attempts",
        "last_error",
        "operator_run_path",
        "watchdog_report_path",
        "policy_sha256",
        "request_sha256",
        "threat_refs",
        "governor_decisions_count",
        "watchdog_safety_status"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "const": "trinity-task-queue-item/v0.1"
        },
        "queue_item_id": {
          "type": "string",
          "pattern": "^qit-[0-9a-f]{16}$"
        },
        "request_json_path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "worker_address_map_path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "governor_policy_path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "request_json_path_basename": { "type": "string", "minLength": 1, "maxLength": 256 },
        "worker_address_map_path_basename": { "type": "string", "minLength": 1, "maxLength": 256 },
        "governor_policy_path_basename": { "type": "string", "minLength": 1, "maxLength": 256 },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed"]
        },
        "created_at": { "type": "string", "minLength": 1, "maxLength": 64 },
        "updated_at": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pinned_time": { "type": "string", "minLength": 1, "maxLength": 64 },
        "attempt_count": { "type": "integer", "minimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 16 },
        "last_error": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 1024 },
            { "type": "null" }
          ]
        },
        "operator_run_path": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 1024 },
            { "type": "null" }
          ]
        },
        "watchdog_report_path": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 1024 },
            { "type": "null" }
          ]
        },
        "policy_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "request_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "threat_refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T[0-9]{2}$" }
        },
        "governor_decisions_count": { "type": "integer", "minimum": 0 },
        "watchdog_safety_status": {
          "oneOf": [
            { "type": "string", "enum": ["ok", "warning", "stale", "critical"] },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
