{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-result/v0.2",
  "title": "Trinity Useful Compute Result",
  "description": "Output emitted by a local-dry-run Useful Compute worker after it has executed a deterministic placeholder task derived from a v0.1 request manifest. v0.2 separates the worker-independent compute_output_sha256 (hash of the pure technical output, used for cross-worker replay) from the worker_result_id (hash that binds the result to one specific worker submission). v0.2 does NOT run real DFT / quantum simulation; it produces a verifiable, deterministic placeholder that the network can replay.",
  "type": "object",
  "required": [
    "schema",
    "request_id",
    "worker_id",
    "task_type",
    "input_bundle_sha256",
    "compute_output_sha256",
    "worker_result_id",
    "started_at",
    "finished_at",
    "elapsed_seconds",
    "result_validated",
    "duplicate_result",
    "public_summary",
    "safety_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-result/v0.2"
    },
    "request_id": {
      "type": "string",
      "pattern": "^uc-[0-9a-f]{16,64}$"
    },
    "worker_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "task_type": {
      "type": "string",
      "enum": [
        "dft", "quantum", "structure_relaxation",
        "scoring", "simulation", "other"
      ]
    },
    "input_bundle_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "compute_output_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$",
      "description": "SHA-256 of the canonical-JSON of the pure technical task output. MUST be independent of worker_id. Two honest workers running the same task on the same input MUST produce the same compute_output_sha256."
    },
    "worker_result_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$",
      "description": "16-hex id binding (request_id, worker_id, compute_output_sha256, elapsed_seconds). Unique per worker submission. Different workers on the same task MUST get different worker_result_id."
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "elapsed_seconds": {
      "type": "number",
      "minimum": 0
    },
    "result_validated": {
      "type": "boolean"
    },
    "duplicate_result": {
      "type": "boolean"
    },
    "public_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "private_notes": {
      "type": "string",
      "maxLength": 2048
    },
    "safety_status": {
      "type": "object",
      "required": [
        "no_wallet_access",
        "no_private_keys",
        "no_automatic_payout",
        "no_network_required",
        "manual_review_required"
      ],
      "additionalProperties": false,
      "properties": {
        "no_wallet_access":        { "type": "boolean", "const": true },
        "no_private_keys":         { "type": "boolean", "const": true },
        "no_automatic_payout":     { "type": "boolean", "const": true },
        "no_network_required":     { "type": "boolean", "const": true },
        "manual_review_required":  { "type": "boolean", "const": true }
      }
    }
  }
}
