{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-result/v0.4",
  "title": "Trinity Useful Compute Result",
  "description": "Output emitted by a local-dry-run Useful Compute worker. v0.4 adds benchmark linkage (benchmark_id, normalized_work_score, benchmark_source) so the reward model can be driven by a deterministic benchmark report instead of trusting elapsed_seconds alone. Backend metadata from v0.3 is unchanged. The compute_output_sha256 MUST remain independent of worker_id; benchmark and backend identifiers are carried alongside but do NOT influence the technical output bytes.",
  "type": "object",
  "required": [
    "schema",
    "request_id",
    "worker_id",
    "task_type",
    "input_bundle_sha256",
    "compute_output_sha256",
    "worker_result_id",
    "started_at",
    "finished_at",
    "elapsed_seconds",
    "result_validated",
    "duplicate_result",
    "public_summary",
    "backend_name",
    "backend_version",
    "backend_kind",
    "backend_disclaimer",
    "backend_runtime_seconds",
    "benchmark_id",
    "normalized_work_score",
    "benchmark_source",
    "safety_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-result/v0.4"
    },
    "request_id": {
      "type": "string",
      "pattern": "^uc-[0-9a-f]{16,64}$"
    },
    "worker_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "task_type": {
      "type": "string",
      "enum": [
        "dft", "quantum", "structure_relaxation",
        "scoring", "simulation", "other",
        "scientific_intake"
      ]
    },
    "input_bundle_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "compute_output_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "worker_result_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "started_at":  { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "elapsed_seconds": { "type": "number", "minimum": 0 },
    "result_validated": { "type": "boolean" },
    "duplicate_result": { "type": "boolean" },
    "public_summary": {
      "type": "string", "minLength": 1, "maxLength": 1024
    },
    "private_notes": {
      "type": "string", "maxLength": 2048
    },
    "backend_name": {
      "type": "string", "minLength": 1, "maxLength": 128
    },
    "backend_version": {
      "type": "string", "minLength": 1, "maxLength": 32
    },
    "backend_kind": {
      "type": "string",
      "enum": ["placeholder", "sandbox_toy", "real_backend"]
    },
    "backend_disclaimer": {
      "type": "string", "minLength": 1, "maxLength": 512
    },
    "backend_runtime_seconds": {
      "type": "number", "minimum": 0
    },
    "benchmark_id": {
      "oneOf": [
        { "type": "string", "pattern": "^bench-[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "normalized_work_score": {
      "oneOf": [
        { "type": "number", "minimum": 0, "maximum": 100 },
        { "type": "null" }
      ]
    },
    "benchmark_source": {
      "type": "string",
      "enum": ["none", "report"]
    },
    "safety_status": {
      "type": "object",
      "required": [
        "no_wallet_access",
        "no_private_keys",
        "no_automatic_payout",
        "no_network_required",
        "manual_review_required"
      ],
      "additionalProperties": false,
      "properties": {
        "no_wallet_access":        { "type": "boolean", "const": true },
        "no_private_keys":         { "type": "boolean", "const": true },
        "no_automatic_payout":     { "type": "boolean", "const": true },
        "no_network_required":     { "type": "boolean", "const": true },
        "manual_review_required":  { "type": "boolean", "const": true }
      }
    },
    "materials_engine_summary": {
      "type": "object",
      "description": "Sprint 5.33 - compact projection of the Sprint 5.32 materials_engine backend output. Optional: only present when backend_name == 'local_materials_engine_v01'. Lives OUTSIDE the hashed output_obj so adding/removing it does NOT change compute_output_sha256. Full schema at schemas/trinity/materials_engine_summary.schema.json.",
      "additionalProperties": false,
      "required": [
        "schema",
        "backend_name",
        "backend_kind",
        "classification_id",
        "known_materials",
        "unknown_materials",
        "resolved_metrics",
        "top_ranked_material",
        "top_ranked_score",
        "ranking",
        "warnings",
        "limitations"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "const": "trinity-materials-engine-summary/v0.1"
        },
        "backend_name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "backend_kind": { "type": "string", "enum": ["placeholder", "sandbox_toy", "real_backend"] },
        "classification_id": {
          "oneOf": [
            { "type": "string", "pattern": "^scl-[0-9a-f]{16}$" },
            { "type": "string", "maxLength": 0 }
          ]
        },
        "known_materials": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "unknown_materials": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "resolved_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["metric", "property", "direction"],
            "properties": {
              "metric":    { "type": "string", "minLength": 1, "maxLength": 64 },
              "property":  { "type": "string", "minLength": 1, "maxLength": 64 },
              "direction": { "type": "string", "enum": ["higher_is_better", "lower_is_better"] }
            }
          }
        },
        "top_ranked_material": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 64 },
            { "type": "null" }
          ]
        },
        "top_ranked_score": {
          "oneOf": [
            { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            { "type": "null" }
          ]
        },
        "ranking": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["material", "score"],
            "properties": {
              "material": { "type": "string", "minLength": 1, "maxLength": 64 },
              "score":    { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      }
    }
  }
}
