{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-request/v0.1",
  "title": "Trinity Useful Compute Request",
  "description": "Manifest describing a deterministic, verifiable compute task that a SOST miner / worker MAY choose to execute. v0.1 is dry-run only — no automatic broadcast, no automatic payout.",
  "type": "object",
  "required": [
    "schema",
    "request_id",
    "source_tool",
    "candidate_id",
    "task_type",
    "input_bundle_sha256",
    "expected_output_schema",
    "validation_method",
    "estimated_compute_cost",
    "max_reward_stocks",
    "deadline",
    "manual_review_required",
    "public_description"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-request/v0.1"
    },
    "request_id": {
      "type": "string",
      "pattern": "^uc-[0-9a-f]{16,64}$",
      "description": "Deterministic id derived from sha256(canonical(manifest_without_request_id))."
    },
    "source_tool": {
      "type": "string",
      "enum": [
        "materials_engine",
        "geaspirit",
        "trinity_orchestrator",
        "trinity_scientific_prompt_intake"
      ]
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "task_type": {
      "type": "string",
      "enum": [
        "dft", "quantum", "structure_relaxation", "scoring",
        "simulation", "other",
        "scientific_intake"
      ]
    },
    "input_bundle_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "expected_output_schema": {
      "type": "string",
      "minLength": 1
    },
    "validation_method": {
      "type": "string",
      "enum": [
        "redundant_replay",
        "cross_worker_consensus",
        "deterministic_hash_check",
        "manual_review"
      ]
    },
    "estimated_compute_cost": {
      "type": "object",
      "required": ["seconds", "tier"],
      "additionalProperties": false,
      "properties": {
        "seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "tier": {
          "type": "string",
          "enum": ["low", "medium", "high", "extreme"]
        }
      }
    },
    "max_reward_stocks": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "manual_review_required": {
      "type": "boolean"
    },
    "public_description": {
      "type": "string",
      "minLength": 8,
      "maxLength": 512
    },
    "private_notes": {
      "type": "string",
      "maxLength": 2048
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scientific_intake": {
          "type": "object",
          "required": [
            "intake_id",
            "combined_context_sha256",
            "prompt_sha256",
            "documents_count",
            "intake_task_kind",
            "intake_artifact_sha256"
          ],
          "additionalProperties": false,
          "properties": {
            "intake_id": {
              "type": "string",
              "pattern": "^spi-[0-9a-f]{16}$"
            },
            "combined_context_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "prompt_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "documents_count": {
              "type": "integer", "minimum": 0
            },
            "intake_task_kind": {
              "type": "string",
              "enum": [
                "benchmark",
                "comparison",
                "extraction",
                "validation"
              ]
            },
            "intake_artifact_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "scientific_task_classification": {
          "type": "object",
          "description": "Sprint 5.31 — projection of the scientific task classification that produced this request. Bulky fields (evidence, public_description, raw counts) live in the classification artifact on disk; only the decision-shape is mirrored here. Optional: legacy task builders pre-Sprint-5.31 omit this field, and the request still validates.",
          "required": [
            "classification_id",
            "source_intake_id",
            "source_intake_sha256",
            "task_kind",
            "confidence",
            "candidate_materials",
            "candidate_metrics",
            "proposed_source_tool",
            "proposed_difficulty_class",
            "threat_refs"
          ],
          "additionalProperties": false,
          "properties": {
            "classification_id": {
              "type": "string", "pattern": "^scl-[0-9a-f]{16}$"
            },
            "source_intake_id": {
              "type": "string", "pattern": "^spi-[0-9a-f]{16}$"
            },
            "source_intake_sha256": {
              "type": "string", "pattern": "^[0-9a-f]{64}$"
            },
            "task_kind": {
              "type": "string",
              "enum": ["comparison", "extraction", "validation", "benchmark"]
            },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "candidate_materials": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 64 }
            },
            "candidate_metrics": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 64 }
            },
            "proposed_source_tool": {
              "type": "string",
              "enum": [
                "materials_engine",
                "trinity_scientific_prompt_intake"
              ]
            },
            "proposed_difficulty_class": {
              "type": "string",
              "enum": ["low", "medium", "high", "extreme"]
            },
            "threat_refs": {
              "type": "array",
              "items": { "type": "string", "pattern": "^T[0-9]{2}$" }
            }
          }
        },
        "scientific_reader_manifest": {
          "type": "object",
          "description": "Sprint 5.30 — mirror of the Sprint 5.29 intake reader metadata, projected down to the subset downstream consumers (workers, operators, dashboards) need. Never includes raw extracted text; never includes absolute paths. Optional: legacy task builders that pre-date Sprint 5.30 omit this field, and the request still validates.",
          "required": [
            "documents_count",
            "combined_context_sha256",
            "reader_kind_counts",
            "reader_status_counts",
            "documents",
            "intake_warnings"
          ],
          "additionalProperties": false,
          "properties": {
            "documents_count": { "type": "integer", "minimum": 0 },
            "combined_context_sha256": {
              "type": "string", "pattern": "^[0-9a-f]{64}$"
            },
            "reader_kind_counts": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 },
              "properties": {}
            },
            "reader_status_counts": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 },
              "properties": {}
            },
            "documents": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "path_basename",
                  "sha256",
                  "reader_kind",
                  "reader_status",
                  "extracted_text_sha256",
                  "structured_summary",
                  "warnings"
                ],
                "additionalProperties": false,
                "properties": {
                  "path_basename": {
                    "type": "string", "minLength": 1, "maxLength": 256
                  },
                  "sha256": {
                    "type": "string", "pattern": "^[0-9a-f]{64}$"
                  },
                  "reader_kind": {
                    "type": "string",
                    "enum": [
                      "text", "json", "pdf", "latex", "csv", "unsupported"
                    ]
                  },
                  "reader_status": {
                    "type": "string",
                    "enum": [
                      "ok",
                      "unsupported_extension",
                      "unsupported_missing_dependency",
                      "parse_error"
                    ]
                  },
                  "extracted_text_sha256": {
                    "type": "string", "pattern": "^[0-9a-f]{64}$"
                  },
                  "structured_summary": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {}
                  },
                  "warnings": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1, "maxLength": 512 }
                  }
                }
              }
            },
            "intake_warnings": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 512 }
            }
          }
        }
      }
    }
  }
}
