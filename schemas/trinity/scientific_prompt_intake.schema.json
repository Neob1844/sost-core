{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-scientific-prompt-intake/v0.1",
  "title": "Trinity Scientific Prompt Intake",
  "description": "Output of scripts/trinity/scientific_prompt_intake.py. Auditable artifact produced when Trinity ingests a scientific prompt and any number of local reference documents. The intake never calls an LLM, never reaches the network, never touches a wallet, never broadcasts. Documents are recorded by basename + sha256 + a bounded text preview only; absolute paths and full content are deliberately NOT stored. safety_status flags are all const-true; a reviewer can spot tampering at a glance.",
  "type": "object",
  "required": [
    "schema",
    "intake_id",
    "mode",
    "pinned_time",
    "prompt_sha256",
    "prompt_preview",
    "documents_count",
    "documents",
    "combined_context_sha256",
    "safety_status",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-scientific-prompt-intake/v0.1"
    },
    "intake_id": {
      "type": "string",
      "pattern": "^spi-[0-9a-f]{16}$"
    },
    "mode": {
      "type": "string",
      "enum": ["local-dry-run"]
    },
    "pinned_time": {
      "type": "string", "minLength": 1, "maxLength": 64
    },
    "prompt_sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "prompt_preview": {
      "type": "string", "minLength": 0, "maxLength": 1024
    },
    "documents_count": { "type": "integer", "minimum": 0 },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path_basename",
          "sha256",
          "bytes",
          "text_preview"
        ],
        "additionalProperties": false,
        "properties": {
          "path_basename": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "sha256": {
            "type": "string", "pattern": "^[0-9a-f]{64}$"
          },
          "bytes":  { "type": "integer", "minimum": 0 },
          "text_preview": {
            "type": "string",
            "minLength": 0,
            "maxLength": 1024
          }
        }
      }
    },
    "combined_context_sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "safety_status": {
      "type": "object",
      "required": [
        "local_only",
        "no_network",
        "no_llm_call",
        "no_wallet_access",
        "no_broadcast",
        "no_private_keys",
        "deterministic_output"
      ],
      "additionalProperties": false,
      "properties": {
        "local_only":           { "type": "boolean", "const": true },
        "no_network":           { "type": "boolean", "const": true },
        "no_llm_call":          { "type": "boolean", "const": true },
        "no_wallet_access":     { "type": "boolean", "const": true },
        "no_broadcast":         { "type": "boolean", "const": true },
        "no_private_keys":      { "type": "boolean", "const": true },
        "deterministic_output": { "type": "boolean", "const": true }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    }
  }
}
