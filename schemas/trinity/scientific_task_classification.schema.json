{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-scientific-task-classification/v0.1",
  "title": "Trinity Scientific Task Classification",
  "description": "Deterministic, local, no-LLM classification of a Sprint 5.20+ scientific intake into a structured task plan suitable for Useful Compute. Produced by scripts/trinity/scientific_task_classifier.py. The classifier never opens the network, never reads any document file (only the bounded intake previews), and never copies full extracted text into its output. Evidence snippets are bounded at 200 chars each.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "classification_id",
    "source_intake_id",
    "source_intake_sha256",
    "combined_context_sha256",
    "documents_count",
    "reader_kind_counts",
    "reader_status_counts",
    "task_kind",
    "confidence",
    "candidate_materials",
    "candidate_metrics",
    "proposed_source_tool",
    "proposed_difficulty_class",
    "expected_output_schema",
    "public_description",
    "warnings",
    "evidence",
    "threat_refs",
    "pinned_time"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-scientific-task-classification/v0.1"
    },
    "classification_id": {
      "type": "string",
      "pattern": "^scl-[0-9a-f]{16}$"
    },
    "source_intake_id": {
      "type": "string",
      "pattern": "^spi-[0-9a-f]{16}$"
    },
    "source_intake_sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "combined_context_sha256": {
      "type": "string", "pattern": "^[0-9a-f]{64}$"
    },
    "documents_count": { "type": "integer", "minimum": 0 },
    "reader_kind_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "properties": {}
    },
    "reader_status_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "properties": {}
    },
    "task_kind": {
      "type": "string",
      "enum": ["comparison", "extraction", "validation", "benchmark"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "candidate_materials": {
      "type": "array",
      "items": {
        "type": "string", "minLength": 1, "maxLength": 64
      }
    },
    "candidate_metrics": {
      "type": "array",
      "items": {
        "type": "string", "minLength": 1, "maxLength": 64
      }
    },
    "proposed_source_tool": {
      "type": "string",
      "enum": [
        "materials_engine",
        "trinity_scientific_prompt_intake"
      ]
    },
    "proposed_difficulty_class": {
      "type": "string",
      "enum": ["low", "medium", "high", "extreme"]
    },
    "expected_output_schema": {
      "type": "string", "minLength": 1, "maxLength": 128
    },
    "public_description": {
      "type": "string", "minLength": 1, "maxLength": 512
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string", "minLength": 1, "maxLength": 256
      }
    },
    "threat_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^T[0-9]{2}$" }
    },
    "pinned_time": {
      "type": "string", "minLength": 1, "maxLength": 64
    }
  }
}
