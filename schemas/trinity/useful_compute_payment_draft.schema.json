{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-useful-compute-payment-draft/v0.2",
  "title": "Trinity Useful Compute Signed Payment Draft",
  "description": "Output of the Trinity payment draft layer v0.2. v0.2 introduces real local signing via the operator's wallet through the existing sost-cli createtx command (single-recipient). One real-sign invocation produces ONE draft per eligible payable item: each draft has exactly one output, one signed_tx_hex and one txid_if_signed. The unsigned-only and dry-sign modes inherited from v0.1 still produce a single multi-output draft with placeholder hex. v0.2 NEVER broadcasts, NEVER calls sendrawtransaction, NEVER exports a private key, and NEVER auto-pays. The schema locks no_broadcast, human_review_required, private_keys_exported=false, requires_separate_broadcast and automatic_payout=false as const; dry_sign_only, wallet_access_used and real_signed are typed boolean because they vary with mode.",
  "type": "object",
  "required": [
    "schema",
    "draft_id",
    "source_proposal_id",
    "mode",
    "signing_mode",
    "signing_scope",
    "selected_worker_id_hash",
    "source_proposal_payable_items_count",
    "unsigned_only",
    "dry_signed",
    "real_signed",
    "total_outputs",
    "total_payment_stocks",
    "total_fee_stocks_estimated",
    "change_stocks_estimated",
    "outputs",
    "capsule_summary",
    "capsule_attached",
    "warnings",
    "safety_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "trinity-useful-compute-payment-draft/v0.2"
    },
    "draft_id": {
      "type": "string",
      "pattern": "^draft-[0-9a-f]{16}$"
    },
    "source_proposal_id": {
      "type": "string",
      "pattern": "^prop-[0-9a-f]{16}$"
    },
    "mode": {
      "type": "string",
      "enum": ["local-dry-run"]
    },
    "signing_mode": {
      "type": "string",
      "enum": [
        "unsigned_only",
        "dry_sign_placeholder",
        "real_sign_local"
      ]
    },
    "signing_scope": {
      "type": "string",
      "enum": [
        "full_proposal",
        "single_payable_item_subset"
      ]
    },
    "selected_worker_id_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "source_proposal_payable_items_count": {
      "type": "integer", "minimum": 0
    },
    "unsigned_only": { "type": "boolean" },
    "dry_signed":    { "type": "boolean" },
    "real_signed":   { "type": "boolean" },
    "wallet_fingerprint_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "signer_label_or_address_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "sost_cli_bin_hash": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{16}$" },
        { "type": "null" }
      ]
    },
    "capsule_attached": { "type": "boolean", "const": false },
    "total_outputs":  { "type": "integer", "minimum": 0 },
    "total_payment_stocks":          { "type": "integer", "minimum": 0 },
    "total_fee_stocks_estimated":    { "type": "integer", "minimum": 0 },
    "change_stocks_estimated":       { "type": "integer", "minimum": 0 },
    "total_input_stocks":  { "type": "integer", "minimum": 0 },
    "total_output_stocks": { "type": "integer", "minimum": 0 },
    "fee_rate_stocks_per_byte": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "selected_utxos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["txid", "vout", "amount_stocks"],
        "additionalProperties": false,
        "properties": {
          "txid":          { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "vout":          { "type": "integer", "minimum": 0 },
          "amount_stocks": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "payout_address",
          "amount_stocks",
          "amount_sost",
          "request_id",
          "worker_result_ids",
          "reason"
        ],
        "additionalProperties": false,
        "properties": {
          "payout_address": {
            "type": "string",
            "pattern": "^sost1[0-9a-f]{40}$"
          },
          "amount_stocks": { "type": "integer", "minimum": 0 },
          "amount_sost":   { "type": "number",  "minimum": 0 },
          "request_id": {
            "type": "string", "pattern": "^uc-[0-9a-f]{16,64}$"
          },
          "worker_result_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[0-9a-f]{16}$" }
          },
          "reason": {
            "type": "string", "minLength": 1, "maxLength": 256
          }
        }
      }
    },
    "capsule_summary": {
      "type": "object",
      "required": ["template", "text", "referenced_files"],
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "enum": ["useful_compute_reward_batch_v1"]
        },
        "text": {
          "type": "string", "minLength": 1, "maxLength": 512
        },
        "referenced_files": {
          "type": "object",
          "required": [
            "budget_id", "governance_batch_ids", "validation_ids"
          ],
          "additionalProperties": false,
          "properties": {
            "budget_id": {
              "type": "string", "pattern": "^bud-[0-9a-f]{16}$"
            },
            "governance_batch_ids": {
              "type": "array",
              "items": {
                "type": "string", "pattern": "^gov-[0-9a-f]{16}$"
              }
            },
            "validation_ids": {
              "type": "array",
              "items": {
                "type": "string", "pattern": "^val-[0-9a-f]{16}$"
              }
            }
          }
        }
      }
    },
    "unsigned_tx_hex": {
      "oneOf": [
        { "type": "string", "minLength": 0, "maxLength": 1048576 },
        { "type": "null" }
      ]
    },
    "signed_tx_hex": {
      "oneOf": [
        { "type": "string", "minLength": 0, "maxLength": 1048576 },
        { "type": "null" }
      ]
    },
    "txid_if_signed": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        { "type": "null" }
      ]
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "safety_status": {
      "type": "object",
      "required": [
        "no_broadcast",
        "human_review_required",
        "dry_sign_only",
        "wallet_access_used",
        "private_keys_exported",
        "requires_separate_broadcast",
        "automatic_payout"
      ],
      "additionalProperties": false,
      "properties": {
        "no_broadcast":               { "type": "boolean", "const": true },
        "human_review_required":      { "type": "boolean", "const": true },
        "dry_sign_only":              { "type": "boolean" },
        "wallet_access_used":         { "type": "boolean" },
        "private_keys_exported":      { "type": "boolean", "const": false },
        "requires_separate_broadcast":{ "type": "boolean", "const": true },
        "automatic_payout":           { "type": "boolean", "const": false }
      }
    }
  }
}
