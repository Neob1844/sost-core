{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trinity-daily-report/v0.1",
  "title": "Trinity Daily Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "report_id",
    "pinned_time",
    "source_dashboard_basename",
    "queue_dir_basename",
    "source_dashboard_id",
    "counts",
    "completed_items",
    "failed_items",
    "top_materials",
    "cache_hits_total",
    "cache_misses_total",
    "workers_seen_total",
    "worker_ids",
    "warnings",
    "drafts_proposals_count",
    "drafts_proposals_basenames",
    "safety_status",
    "safety_flags",
    "latest_batches_count"
  ],
  "properties": {
    "schema": {"type": "string", "const": "trinity-daily-report/v0.1"},
    "report_id": {
      "type": "string",
      "pattern": "^tdr-[0-9a-f]{16}$"
    },
    "pinned_time": {
      "type": "string",
      "minLength": 10,
      "maxLength": 64
    },
    "source_dashboard_basename": {
      "type": "string",
      "maxLength": 256
    },
    "queue_dir_basename": {
      "type": "string",
      "maxLength": 128
    },
    "source_dashboard_id": {
      "type": "string",
      "maxLength": 64
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pending", "running", "completed", "failed", "batches"],
      "properties": {
        "pending":   {"type": "integer", "minimum": 0},
        "running":   {"type": "integer", "minimum": 0},
        "completed": {"type": "integer", "minimum": 0},
        "failed":    {"type": "integer", "minimum": 0},
        "batches":   {"type": "integer", "minimum": 0}
      }
    },
    "completed_items": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "queue_item_id",
          "top_material",
          "materials_engine_known_count",
          "materials_engine_unknown_count",
          "materials_project_cache_hits",
          "materials_project_cache_misses",
          "workers_seen"
        ],
        "properties": {
          "queue_item_id":  {"type": "string", "maxLength": 64},
          "top_material":   {"type": ["string", "null"], "maxLength": 64},
          "materials_engine_known_count":   {"type": "integer", "minimum": 0},
          "materials_engine_unknown_count": {"type": "integer", "minimum": 0},
          "materials_project_cache_hits":   {"type": "integer", "minimum": 0},
          "materials_project_cache_misses": {"type": "integer", "minimum": 0},
          "workers_seen":                   {"type": "integer", "minimum": 0}
        }
      }
    },
    "failed_items": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["queue_item_id", "watchdog_safety_status"],
        "properties": {
          "queue_item_id": {"type": "string", "maxLength": 64},
          "watchdog_safety_status": {
            "type": ["string", "null"],
            "enum": [null, "ok", "warning", "stale", "critical"]
          }
        }
      }
    },
    "top_materials": {
      "type": "array",
      "maxItems": 50,
      "items": {"type": "string", "minLength": 1, "maxLength": 64}
    },
    "cache_hits_total":   {"type": "integer", "minimum": 0},
    "cache_misses_total": {"type": "integer", "minimum": 0},
    "workers_seen_total": {"type": "integer", "minimum": 0},
    "worker_ids": {
      "type": "array",
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 32}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "drafts_proposals_count": {"type": "integer", "minimum": 0},
    "drafts_proposals_basenames": {
      "type": "array",
      "maxItems": 50,
      "items": {"type": "string", "maxLength": 256}
    },
    "safety_status": {
      "type": "string",
      "enum": ["ok", "warning", "failed"]
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "no_wallet",
        "no_private_key",
        "no_signing",
        "no_broadcast",
        "no_autonomous_payment",
        "no_network"
      ],
      "properties": {
        "no_wallet":             {"type": "boolean", "const": true},
        "no_private_key":        {"type": "boolean", "const": true},
        "no_signing":            {"type": "boolean", "const": true},
        "no_broadcast":          {"type": "boolean", "const": true},
        "no_autonomous_payment": {"type": "boolean", "const": true},
        "no_network":            {"type": "boolean", "const": true}
      }
    },
    "latest_batches_count": {"type": "integer", "minimum": 0}
  }
}
