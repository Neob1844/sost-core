# =============================================================================
# .env.example for scripts/soak_popc_v15_testnet.sh
#
# Copy to .env, fill the values, then:
#   set -a; . ./.env; set +a; ./scripts/soak_popc_v15_testnet.sh
# Runs ONLY against a TESTNET_FORKS=ON node (V15=300). Never point at mainnet.
# =============================================================================

# Node JSON-RPC endpoint of the running TESTNET binary.
RPC_URL=http://127.0.0.1:18299/rpc

# Optional curl auth, if your RPC requires it (else leave empty).
#   e.g. RPC_AUTH="-u rpcuser:rpcpass"
RPC_AUTH=

# REQUIRED. Command that mines $1 blocks to address $2. $1 and $2 are substituted
# literally by the script. Examples (pick/adapt to your miner):
#   MINER_CMD='/opt/sost/sost-miner --rpc http://127.0.0.1:18299/rpc --blocks $1 --address $2'
#   MINER_CMD='python3 /opt/sost/miner.py --count $1 --to $2'
MINER_CMD=

# SOST address that mines/receives. Leave empty to let the script call getnewaddress.
WALLET_ADDR=

# Declared Ethereum EOA for the PoPC commitment (any test EOA; must be a plain EOA).
ETH_ADDR=0xd38955822b88867CD010946F0Ba25680B9DfC7a6

# Path to the node's popc_registry.json (the script patches gold_verified_days here
# for Scenario B — TEST FIXTURE only; production value comes from the verification
# pipeline, see docs/GOLD_BOOST_CONTINUOUS_VERIFICATION_STUB.md).
POPC_REGISTRY=/path/to/popc_registry.json

# Out-of-source build dir for the testnet binary.
BUILD_DIR=build-testnet

# --- Commitment shape (defaults are sensible; override only if needed) --------
# Gold token: XAUT or PAXG.
GOLD_TOKEN=PAXG
# Gold amount in milligrams. 50000 mg ≈ 1.6 oz — well above the 0.25 oz dust floor,
# so eligibility (>= max(25% of bond value, 0.25 PAXG/XAUT)) is comfortably met.
GOLD_MG=50000
# Lock duration in months (1/3/6/9/12). 12 = 20% base reward tier.
MONTHS=12
# Mine to at least this height before registering (must be > V15=300).
TARGET_START=320
