# =============================================================================
# .env.example for scripts/soak_popc_v15_testnet.sh
#
# Run the soak ON THE VPS (where the node + popc_registry.json live). The chain
# only needs to be PAST V15 (testnet=300); no mining to a real end_height — the
# script uses a registry FIXTURE for end_height (PoPC durations are thousands of
# blocks and are not scaled on testnet).
#
#   cp scripts/soak_popc_v15_testnet.env.example .env && edit
#   set -a; . ./.env; set +a; ./scripts/soak_popc_v15_testnet.sh
# Never point at a mainnet node.
# =============================================================================

# Node JSON-RPC endpoint of the running TESTNET binary.
RPC_URL=http://127.0.0.1:18399/rpc

# Curl auth for the RPC (the testnet node uses basic auth).
#   RPC_AUTH="-u $RPC_USER:$RPC_PASS"   (after: source /etc/sost/rpc.env)
RPC_AUTH=

# Path to the node's popc_registry.json (the script patches end_height +
# gold_verified_days here — TEST FIXTURE; production values come from the chain /
# verification pipeline).
POPC_REGISTRY=/opt/sost/testnet-soak/popc_registry.json

# SOST address that receives the reward (blank -> the script calls getnewaddress).
WALLET_ADDR=sost1ad01a1ce3ae7d0dbcc1baae7a11e9ecde28683a2

# Declared Ethereum EOA for the commitment (any test EOA).
ETH_ADDR=0xd38955822b88867CD010946F0Ba25680B9DfC7a6

# OPTIONAL: command that restarts the node so it reloads the patched registry.
# Leave empty to have the script pause and let you stop/start the node by hand.
#   NODE_RESTART_CMD='systemctl restart sost-testnet'
NODE_RESTART_CMD=

# --- Commitment shape (defaults are sensible) ---------------------------------
GOLD_TOKEN=PAXG
GOLD_MG=50000        # ~1.6 oz — comfortably above the 0.25 oz dust floor (eligibility)
MONTHS_A=12          # distinct months => distinct commitment_id for A and B
MONTHS_B=9
