# SOST Auth Configuration — EXAMPLE
# Copy to /etc/sost/auth.env (production) or ~/.sost/auth.env (dev)
# NEVER commit the real file to the repository.
#
# Generate all values with: python3 -m auth.setup_admin

SOST_ADMIN_USER=admin
SOST_ADMIN_PASS_HASH=<run setup_admin.py to generate>
SOST_2FA_SECRET=<TOTP base32 secret from setup_admin.py — scan QR with Google Authenticator>
SOST_2FA_ENABLED=true
SOST_SESSION_SECRET=<random 64 hex chars from setup_admin.py>
