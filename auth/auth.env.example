# SOST Auth Configuration — EXAMPLE
# Copy to /etc/sost/auth.env (production) or ~/.sost/auth.env (dev)
# NEVER commit the real file to the repository.
#
# Generate SOST_ADMIN_PASS_HASH with:
#   python3 -m auth.setup_admin

SOST_ADMIN_USER=admin
SOST_ADMIN_PASS_HASH=<run setup_admin.py to generate>
SOST_SESSION_SECRET=<random 64 hex chars: python3 -c "import secrets; print(secrets.token_hex(32))">
SOST_OTP_PHONE=<phone number for SMS 2FA, e.g. +34612345678>
SOST_SMS_API_KEY=<provider API key if using real SMS>
